<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TicTacToeAI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TicTacToeAI"
    xmlns:pages="clr-namespace:TicTacToeAI.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="True"
    Shell.BackgroundColor="#16213e"
    Shell.ForegroundColor="#e94560"
    Shell.TitleColor="#eaeaea"
    Shell.UnselectedColor="#888888"
    Title="TicTacToe AI">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
